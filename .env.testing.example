# .env.testing — konfigurasi database untuk composer test
#
# Copy file ini ke .env.testing dan isi sesuai environment lokal:
#   cp .env.testing.example .env.testing
#
# File .env.testing sudah ada di .gitignore — tidak akan ikut di-commit.

APP_ENV=testing
APP_KEY=base64:2fl+Ktvkfl+Ktvkfl+Ktvkfl+Ktvkfl+Ktvkfl+Ktv=

# Ganti ke 'mysql' untuk pakai MySQL, biarkan 'sqlite' untuk SQLite in-memory
DB_CONNECTION=mysql

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bale_umpak_test
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
