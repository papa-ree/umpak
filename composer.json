{
    "name": "bale/umpak",
    "description": "Bale Landing Page Foundation Package",
    "keywords": [
        "bale",
        "laravel",
        "landing-page",
        "umpak"
    ],
    "homepage": "https://github.com/papa-ree/umpak",
    "license": "MIT",
    "authors": [
        {
            "name": "Ricky Romdhoni",
            "email": "ricky.romdhoni@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0||^12.0||^13.0",
        "livewire/livewire": "^4.0",
        "mallardduck/blade-lucide-icons": "*"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "suggest": {
        "bale/seo": "Required for SEO meta tags, sitemap, and robots.txt support"
    },
    "autoload": {
        "psr-4": {
            "Bale\\Umpak\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Bale\\Umpak\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bale\\Umpak\\UmpakServiceProvider"
            ],
            "aliases": {
                "Umpak": "Bale\\Umpak\\Facades\\Umpak"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
